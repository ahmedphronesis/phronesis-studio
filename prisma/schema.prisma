// Prisma schema — Studio of Phronesis
// Production: Neon PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  gap       String
  budget    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leads")
}
